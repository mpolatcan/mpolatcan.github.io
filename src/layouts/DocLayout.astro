---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  doc?: CollectionEntry<'docs'>;
  title?: string;
  description?: string;
}

const { doc, title: pageTitle, description: pageDesc } = Astro.props;
const title = doc?.data.title ?? pageTitle ?? 'Claude Code Dynamic Workflows';
const description = doc?.data.description ?? pageDesc ?? '';

const allDocs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
const currentId = doc?.id;

const formatSectionLabel = (slug: string) =>
  slug === '_root' ? 'General' :
  slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

const sectionMap = new Map<string, typeof allDocs>();
for (const d of allDocs) {
  const key = d.id.includes('/') ? d.id.split('/')[0] : '_root';
  if (!sectionMap.has(key)) sectionMap.set(key, []);
  sectionMap.get(key)!.push(d);
}
const docSections = [...sectionMap.entries()].map(([slug, docs]) => ({
  slug, label: formatSectionLabel(slug), docs,
}));
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Claude Code Dynamic Workflows</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
  <script is:inline>
    mermaid.initialize({ startOnLoad: false });
    document.addEventListener('DOMContentLoaded', function() {
      var sel = 'pre code.language-mermaid, pre[data-language="mermaid"] code';
      document.querySelectorAll(sel).forEach(function(el) {
        var pre = el.parentElement;
        var div = document.createElement('div');
        div.className = 'mermaid';
        div.textContent = el.textContent;
        pre.replaceWith(div);
      });
      mermaid.initialize({
        startOnLoad: false,
        theme: 'base',
        themeVariables: {
          background:              '#080B10',
          primaryColor:            '#0F1419',
          primaryBorderColor:      '#1E2830',
          primaryTextColor:        '#E8E4DB',
          secondaryColor:          '#141C25',
          secondaryBorderColor:    '#1E2830',
          secondaryTextColor:      '#E8E4DB',
          tertiaryColor:           '#1E2830',
          tertiaryBorderColor:     '#243040',
          tertiaryTextColor:       '#E8E4DB',
          lineColor:               '#6EE7B7',
          edgeLabelBackground:     '#0F1419',
          clusterBkg:              '#0D1117',
          clusterBorder:           '#1E2830',
          titleColor:              '#E8E4DB',
          noteBkgColor:            '#141C25',
          noteBorderColor:         '#1E2830',
          noteTextColor:           '#8A9BB0',
          actorBkg:                '#0F1419',
          actorBorder:             '#1E2830',
          actorTextColor:          '#E8E4DB',
          actorLineColor:          '#1E2830',
          signalColor:             '#8A9BB0',
          signalTextColor:         '#E8E4DB',
          activationBkgColor:      '#141C25',
          activationBorderColor:   '#6EE7B7',
          labelBoxBkgColor:        '#0F1419',
          labelBoxBorderColor:     '#1E2830',
          labelTextColor:          '#E8E4DB',
          loopTextColor:           '#E8E4DB',
          sequenceNumberColor:     '#6EE7B7',
          fillType0:               '#0F1419',
          fillType1:               '#141C25',
          fillType2:               '#1E2830',
          fillType3:               '#0F1419',
          fillType4:               '#141C25',
          fillType5:               '#1E2830',
          fillType6:               '#0F1419',
          fillType7:               '#141C25',
          fontFamily:              'Inter, sans-serif',
          fontSize:                '14px',
        }
      });
      mermaid.run();
    });
  </script>
</head>
<body>
  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <a href="/" class="logo">
          <span class="logo-mark">▸</span>
          <span class="logo-text">Claude Code<br/><em>Dynamic Workflows</em></span>
        </a>
        <button class="sidebar-close" id="sidebarClose" aria-label="Close sidebar">✕</button>
      </div>

      {docSections.map(section => (
        <div>
          <div class="sidebar-section-label">{section.label}</div>
          <nav class="sidebar-nav">
            {section.docs.map(d => (
              <a
                href={`/notes/${d.id.replace('.md', '')}/`}
                class:list={['nav-item', { active: d.id === currentId }]}
              >
                <span class="nav-badge">{d.data.badge}</span>
                <span class="nav-title">{d.data.title}</span>
              </a>
            ))}
          </nav>
        </div>
      ))}

      <div class="sidebar-footer">
        <a href="https://github.com/mpolatcan/mpolatcan.github.io" target="_blank" rel="noopener" class="footer-link">
          GitHub
        </a>
        <span class="footer-sep">·</span>
        <span class="footer-note">v2.1.193</span>
      </div>
    </aside>

    <!-- Overlay for mobile -->
    <div class="overlay" id="overlay"></div>

    <!-- Main -->
    <div class="main-wrapper">
      <header class="topbar">
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <a href="/" class="topbar-home">← Home</a>
        <div class="topbar-title">{title}</div>
      </header>

      <main class="content">
        <slot />
      </main>
    </div>
  </div>

  <div id="read-progress" aria-hidden="true"></div>

  <script is:inline>
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('overlay');
    const menuBtn = document.getElementById('menuBtn');
    const closeBtn = document.getElementById('sidebarClose');
    const progress = document.getElementById('read-progress');

    function openSidebar() {
      sidebar.classList.add('open');
      overlay.classList.add('visible');
    }
    function closeSidebar() {
      sidebar.classList.remove('open');
      overlay.classList.remove('visible');
    }

    menuBtn?.addEventListener('click', openSidebar);
    closeBtn?.addEventListener('click', closeSidebar);
    overlay?.addEventListener('click', closeSidebar);

    function updateProgress() {
      var el = document.documentElement;
      var scrolled = el.scrollTop || document.body.scrollTop;
      var total = el.scrollHeight - el.clientHeight;
      var pct = total > 0 ? (scrolled / total) * 100 : 0;
      if (progress) progress.style.width = pct + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  </script>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080B10;
    --surface: #0F1419;
    --surface-hover: #141C25;
    --border: #1E2830;
    --text: #E8E4DB;
    --text-muted: #8A9BB0;
    --accent: #6EE7B7;
    --accent-dim: rgba(110, 231, 183, 0.08);
    --code-bg: #0D1117;
    --sidebar-w: 260px;
    --topbar-h: 52px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* Layout */
  .layout { display: flex; min-height: 100vh; }

  /* Sidebar */
  .sidebar {
    width: var(--sidebar-w);
    flex-shrink: 0;
    background: var(--surface);
    border-right: 1px solid var(--border);
    position: fixed;
    top: 0; left: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    z-index: 100;
    transition: transform 0.25s ease;
  }

  .sidebar-header {
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }

  .logo-mark {
    color: var(--accent);
    font-size: 20px;
    line-height: 1;
    font-family: 'JetBrains Mono', monospace;
  }

  .logo-text {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  .logo-text em {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 13px;
    color: var(--accent);
    display: block;
  }

  .sidebar-close {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 14px;
    padding: 2px 4px;
    display: none;
  }

  .sidebar-section-label {
    padding: 16px 20px 6px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .sidebar-nav {
    flex: 1;
    padding: 4px 10px;
  }

  .nav-item {
    display: block;
    padding: 10px 12px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-muted);
    margin-bottom: 2px;
    transition: background 0.15s, color 0.15s;
  }

  .nav-item:hover {
    background: var(--surface-hover);
    color: var(--text);
  }

  .nav-item.active {
    background: linear-gradient(90deg, var(--accent-dim), transparent);
    color: var(--text);
    border-left: 2px solid var(--accent);
  }

  .nav-badge {
    display: block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2px;
    font-family: 'JetBrains Mono', monospace;
  }

  .nav-title {
    display: block;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
  }

  .sidebar-footer {
    padding: 14px 20px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer-link {
    color: var(--text-muted);
    text-decoration: none;
  }
  .footer-link:hover { color: var(--accent); }
  .footer-sep { opacity: 0.4; }

  /* Main wrapper */
  .main-wrapper {
    margin-left: var(--sidebar-w);
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* Topbar */
  .topbar {
    height: var(--topbar-h);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 32px;
    gap: 16px;
    position: sticky;
    top: 0;
    background: rgba(8, 11, 16, 0.92);
    backdrop-filter: blur(8px);
    z-index: 50;
  }

  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .menu-btn span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text-muted);
    border-radius: 2px;
  }

  .topbar-home {
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
  }
  .topbar-home:hover { color: var(--accent); }

  .topbar-title {
    font-size: 13px;
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Content */
  .content {
    max-width: 960px;
    padding: 48px 48px 96px;
    width: 100%;
    margin: 0 auto;
  }

  /* Overlay */
  .overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 90;
  }
  .overlay.visible { display: block; }

  /* Markdown content styles */
  .content h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 2.4rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 16px;
    margin-top: 0;
  }

  .content h2 {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 52px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .content h2::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 32px;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }

  .content h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 32px;
    margin-bottom: 10px;
  }

  .content h4 {
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-top: 24px;
    margin-bottom: 8px;
  }

  .content p {
    margin-bottom: 16px;
    color: var(--text);
  }

  .content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(110, 231, 183, 0.3);
    transition: border-color 0.15s;
  }

  .content a:hover {
    border-bottom-color: var(--accent);
  }

  .content code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82em;
    background: var(--code-bg);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: #79C0FF;
  }

  .content pre {
    background: var(--code-bg) !important;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 20px 0;
    font-size: 0.84em;
    line-height: 1.6;
  }

  .content pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 1em;
    color: inherit;
  }

  .content blockquote {
    border-left: 3px solid var(--accent);
    padding: 14px 20px;
    margin: 24px 0;
    background: var(--accent-dim);
    border-radius: 0 6px 6px 0;
    color: var(--text);
  }

  .content blockquote p { margin-bottom: 0; color: var(--text); }

  .content ul, .content ol {
    padding-left: 24px;
    margin-bottom: 16px;
  }

  .content li {
    margin-bottom: 6px;
    color: var(--text);
  }

  .content table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 0.9em;
  }

  .content th {
    background: var(--surface);
    padding: 10px 14px;
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  .content td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .content tr:last-child td { border-bottom: none; }

  .content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }

  /* Mermaid diagrams */
  .content .mermaid {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px;
    margin: 20px 0;
    overflow-x: auto;
    text-align: center;
  }

  .content .mermaid svg {
    max-width: 100%;
    height: auto;
    font-family: 'Inter', sans-serif !important;
  }

  /* Status badges in content */
  .content p:has(> strong:only-child) strong,
  .content li > strong:first-child {
    color: var(--accent);
  }

  /* Reading progress bar */
  #read-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--accent);
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
  }

  /* Selection highlight */
  ::selection {
    background: rgba(110, 231, 183, 0.2);
    color: var(--text);
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

  /* Scroll offset for anchors under sticky topbar */
  .content h2, .content h3, .content h4 {
    scroll-margin-top: calc(var(--topbar-h) + 20px);
  }

  /* Keyboard focus */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }

  /* Table row hover */
  .content tbody tr:hover td {
    background: rgba(110, 231, 183, 0.04);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.open {
      transform: translateX(0);
    }

    .sidebar-close { display: block; }
    .menu-btn { display: flex; }

    .main-wrapper {
      margin-left: 0;
    }

    .topbar {
      padding: 0 16px;
    }

    .content {
      padding: 32px 20px 64px;
    }

    .content h1 { font-size: 1.8rem; }
  }
</style>
